{
  "name": "lumos",
  "productName": "lumos",
  "version": "1.0.0",
  "private": true,
  "description": "Electron + Vite desktop app starter with Vue renderer, preload bridge, routing, and i18n.",
  "author": {
    "name": "ckvv",
    "email": "k_0520@qq.com"
  },
  "license": "MIT",
  "keywords": [],
  "imports": {
    "#main/*": "./src/main/*",
    "#preload/*": "./src/preload/*",
    "#renderer/*": "./src/renderer/*",
    "#shared/*": "./src/shared/*"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:delete": "node --experimental-strip-types scripts/delete-db.mts",
    "db:studio": "drizzle-kit studio",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "release:beta": "npx changelogen --prerelease beta --release --push",
    "release": "npx changelogen --patch --release --push"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.58.4",
    "@nuxt/ui": "^4.5.1",
    "@orpc/client": "^1.13.7",
    "@orpc/server": "^1.13.7",
    "@vueuse/core": "^14.2.1",
    "drizzle-orm": "1.0.0-beta.18-5cac498",
    "electron-squirrel-startup": "^1.0.1",
    "markstream-vue": "0.0.9-beta.1",
    "orpc": "^0.1.1",
    "pino": "^10.3.1",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^2.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "changelogen": "0.6.2",
    "drizzle-kit": "1.0.0-beta.18-5cac498",
    "electron": "41.0.2",
    "eslint": "^10.0.3",
    "nano-staged": "^0.9.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.1",
    "typescript": "6.0.1-rc",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged",
    "commit-msg": "node --experimental-strip-types scripts/verify-commit-msg.mts $1"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,tsx,jsx,vue}": [
      "eslint --fix"
    ]
  }
}
