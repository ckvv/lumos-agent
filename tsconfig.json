{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "rootDir": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "#main/*": ["./src/main/*"],
      "#preload/*": ["./src/preload/*"],
      "#renderer/*": ["./src/renderer/*"],
      "#shared/*": ["./src/shared/*"]
    },
    "resolveJsonModule": true,
    "resolvePackageJsonImports": true,
    "types": ["vite/client"],
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
